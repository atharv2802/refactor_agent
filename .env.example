# --- LLM ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Vapi (voice mode only) ---
VAPI_PUBLIC_KEY=your-vapi-public-key
# Shared secret used to authenticate inbound Vapi webhooks. Set the same value
# in the Vapi dashboard server-message auth header.
VAPI_WEBHOOK_SECRET=change-me

# Public URL the server is reachable at (e.g. your ngrok https URL).
SERVER_URL=https://xxxx.ngrok.io

# --- Output ---
OUTPUT_DIR=./results

# --- Voice settings ---
# Vapi's built-in voice provider; voice IDs are friendly names like "Elliot".
VOICE_PROVIDER=vapi
VOICE_ID=Elliot

# --- Safety / engine limits ---
MAX_TURNS=50
MAX_TOOL_CALLS=10
MAX_RESPONSE_CHARS=500
